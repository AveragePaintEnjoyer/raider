[Unit]
Description=Raider Web Application
After=network.target

[Service]
User={{ webapp_user }}
Group={{ webapp_user }}
WorkingDirectory={{ app_path }}

ExecStart=/usr/local/bin/raider
Restart=always
RestartSec=3

# security hardening (recommended)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target